# Template file for 'caerus'
#
# Follows the usual Void "-git"-style pattern: do_fetch() clones the
# repo directly (tracking main) instead of using distfiles/checksum.
# Push local commits to origin/main before rebuilding with xbps-src,
# since do_fetch always pulls from GitHub, not this working tree.
# `version` mirrors the latest tagged release main corresponds to.
#
# To use: copy or symlink this directory to <void-packages checkout>/srcpkgs/caerus,
# then from inside that checkout: ./xbps-src pkg caerus
pkgname=caerus
version=0.5.0
revision=1
build_style=cargo
hostmakedepends="pkg-config clang git"
makedepends="gtk4-devel libxbps-devel glib-devel"
depends="polkit"
short_desc="Synaptic-inspired GTK4 package manager for Void Linux, built on libxbps"
maintainer="gui <mendescotta@gmail.com>"
license="GPL-3.0-or-later"
homepage="https://github.com/mendescotta/Caerus"

do_fetch() {
	git clone https://github.com/mendescotta/Caerus.git "${wrksrc}"
}

do_install() {
	vbin target/${RUST_TARGET}/release/caerus
	vinstall target/${RUST_TARGET}/release/caerus-helper 755 usr/libexec

	vinstall caerus/data/org.voidlinux.caerus.policy 644 usr/share/polkit-1/actions
	vinstall caerus/data/org.voidlinux.caerus.desktop 644 usr/share/applications
	vinstall caerus/data/org.voidlinux.caerus.metainfo.xml 644 usr/share/metainfo
	vinstall caerus/data/icons/hicolor/scalable/apps/org.voidlinux.caerus.svg \
		644 usr/share/icons/hicolor/scalable/apps

	# Bundled fallback copies of the symbolic icons the UI uses (see
	# ensure_icon_theme_fallback() in caerus/src/ui/window.rs) — installed
	# under hicolor, which every icon theme falls back to automatically.
	# scalable/, not a symbolic/ directory: hicolor's own index.theme only
	# ever declares scalable/<context> (and symbolic/apps, nothing else
	# under symbolic/), so that's what actually gets scanned; GTK still
	# recolors a "*-symbolic"-suffixed icon correctly wherever it's found.
	# apps/ is excluded — the logo above already installs it.
	find caerus/data/icons/hicolor/scalable -name '*.svg' -not -path '*/apps/*' \
	| while read -r svg; do
		rel="${svg#caerus/data/icons/hicolor/}"
		vinstall "${svg}" 644 "usr/share/icons/hicolor/$(dirname "${rel}")"
	done

	vlicense LICENSE
}
